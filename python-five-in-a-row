checkerboard = []
i = 0
for i in range(10):
    row = []
    j = 0
    for j in range(10):
        row.append(".")
    checkerboard.append(row)
    #棋盘设计10*10
    #接下来是打印棋盘

def print_board():
  print(" ",end=" ")
  m = 0
  for m in range(10):
     print(m, end=" ")
  print()
  n = 1
  l = 1
  for n in range(10):
      print(n,end=" ")
